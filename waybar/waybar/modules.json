{
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": ["≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ", "Όσκ"]
  },
  "battery": {
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon} ",
    "format-charging": "{capacity}% ΎΘο ",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "max-length": 30
  },
  "custom/battery": {
    "exec": "~/.config/waybar/scripts/battery.sh",
    "format": {},
    "return-type": "json"
  },
  "clock": {
    "format-alt": "{:%a, %d. %b  %H:%M}"
  },
  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "{essid} ({signalStrength}%) ΎΘτ ",
    "format-ethernet": "{ifname} ΎΔΒ ",
    "format-disconnected": "No wifi",
    "tooltip-format": "{ifname}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ ",
    "tooltip-format-ethernet": "{ifname} ΎΔΒ ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/my_scripts/wifi_wofi.sh --rofi"
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "show-special": true,
    "format": "{name}{windows}",
    "window-rewrite-default": "",
    "window-rewrite": {
      "class<firefox>": "ΌζΖ",
      "class<.*Deezer.*>": "",
      "class<neovide>": "Όγχ",
      "class<.*teams.*>": "≤░Λ╗",
      "class<.*emacs.*>": "Όα▓",
      "title<.*nvim.*>": "ΎΞψ",
      "title<.*Discord.*>": "",
      "class<obsidian>": "ΎΚΛ",
      "class<libreoffice-impress>": "≤▒ΟΡ",
      "class<Postman>": "Όκτ"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "hyprland/window": {
    "format": "{}",
    "icon": true,
    "icon-size": 20,
    "rewrite": {
      ".* -- Mozilla Firefox": "$1"
    }
  },
  "hyprland/submap": {
    "format": "{}",
    "max-length": 8,
    "tooltip": false
  },
  "custom/logo": {
    "format": "<span font='17' rise='-1000'> ΎΝΔ </span>",
    "on-click": "~/my_scripts/logout.sh"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} ΎΛΦ",
    "format-muted": "ΎΑο",
    "format-icons": {
      "headphones": "ΎΑξ",
      "headset": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑπ", "ΎΑρ"]
    },
    "scroll-step": 1,
    "on-click": "flatpak run com.saivert.pwvucontrol"
  },
  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetooth.sh",
    "format": {},
    "return-type": "json",
    "on-click": "rofi-bluetooth"
  },
  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{status_icon} <i>{title} - {artist}</i>",
    "player-icons": {
      "default": "<span font='15' rise='-1000'>≤░ΡΛ</span>",
      "mpv": "<span font='15' rise='-1000'>ΏθΟ╡</span>"
    },
    "status-icons": {
      "paused": "<span font='15' rise='-1000'>≤░Πν</span>"
    },
    "max-length": 50
  },
  "custom/skip": {
    "format": "<span font='15' rise='-1000'>≤░Τφ</span>",
    "on-click": "playerctl next track"
  },
  "custom/go-back": {
    "format": "<span font='15' rise='-1000'>≤░Τχ</span>",
    "on-click": "playerctl previous track"
  },
  "cpu": {
    "format": "≤░╗ι {usage}%",
    "on-click": "alacritty -e htop"
  },
  "custom/temperature_gpu": {
    "exec": "~/.config/waybar/scripts/temp_gpu.sh",
    "format": {},
    "return-type": "json"
  },
  "custom/temperature_cpu": {
    "exec": "~/.config/waybar/scripts/temp_cpu.sh",
    "format": {},
    "return-type": "json"
  },
  "memory": {
    "format": "  {}% ΎΤ╝ ",
    "on-click": "alacritty -e htop"
  },
  "disk": {
    "interval": 30,
    "format": "{percentage_used}% ≤░ρμ",
    "path": "/",
    "on-click": "alacritty -e htop"
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["memory", "cpu", "custom/temperature_cpu", "disk"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "≤▒β▒",
      "deactivated": "≤░Ν╛"
    }
  },
  "custom/cava_mviz": {
    "exec": "$HOME/.config/waybar/scripts/cava.sh",
    "format": "{}"
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "Όχγ",
      "none": "Όςλ",
      "dnd-notification": "≤░╡β",
      "dnd-none": "≤░Γδ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
