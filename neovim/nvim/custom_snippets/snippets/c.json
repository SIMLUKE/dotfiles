{
  "include_stdio": {
    "prefix": "inc",
    "body": ["#include <${1:stdio.h}>"],
    "description": "Include header"
  },
  "main": {
    "prefix": "main",
    "body": [
      "int main(int argc, char* argv[]) {",
      "\t$0",
      "\treturn 0;",
      "}"
    ],
    "description": "Main function"
  },
  "printf": {
    "prefix": "pf",
    "body": ["printf(\"${1:%s}\\n\"${2:, ${3:variable}});"],
    "description": "Printf statement"
  },
  "fprintf": {
    "prefix": "fpf",
    "body": ["fprintf(${1:stderr}, \"${2:%s}\\n\"${3:, ${4:variable}});"],
    "description": "Fprintf statement"
  },
  "for": {
    "prefix": "fori",
    "body": [
      "for (int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {",
      "\t$0",
      "}"
    ],
    "description": "For loop"
  },
  "while": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "ifelse": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If-else statement"
  },
  "struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:name} {",
      "\t$0",
      "};"
    ],
    "description": "Struct definition"
  },
  "typedef_struct": {
    "prefix": "typestruct",
    "body": [
      "typedef struct ${1:name} {",
      "\t$0",
      "} ${1:name}_t;"
    ],
    "description": "Typedef struct"
  },
  "malloc": {
    "prefix": "malloc",
    "body": ["${1:type}* ${2:ptr} = (${1:type}*)malloc(sizeof(${1:type}) * ${3:n});"],
    "description": "Malloc allocation"
  },
  "calloc": {
    "prefix": "calloc",
    "body": ["${1:type}* ${2:ptr} = (${1:type}*)calloc(${3:n}, sizeof(${1:type}));"],
    "description": "Calloc allocation"
  },
  "free": {
    "prefix": "free",
    "body": [
      "free(${1:ptr});",
      "${1:ptr} = NULL;"
    ],
    "description": "Free and nullify pointer"
  },
  "function": {
    "prefix": "fn",
    "body": [
      "${1:void} ${2:function_name}(${3:void}) {",
      "\t$0",
      "}"
    ],
    "description": "Function definition"
  },
  "include_guard": {
    "prefix": "guard",
    "body": [
      "#ifndef ${1:HEADER_NAME}_H",
      "#define ${1:HEADER_NAME}_H",
      "",
      "$0",
      "",
      "#endif /* ${1:HEADER_NAME}_H */"
    ],
    "description": "Include guard"
  }
}
